{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ../node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "build": "node ../node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "test": "node ../node_modules/vitest/vitest.mjs run",
    "seed:bootstrap": "node ../node_modules/tsx/dist/cli.mjs src/seed/bootstrapAdmin.ts",
    "db:push": "node ../node_modules/prisma/build/index.js db push --schema prisma/schema.prisma",
    "prisma:generate": "node ../node_modules/prisma/build/index.js generate --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/session": "^11.1.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "prisma": "^6.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
