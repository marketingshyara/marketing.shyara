{
  "name": "shyara-marketing-workspace",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -k -n frontend,backend \"npm run dev --workspace frontend\" \"npm run dev --workspace backend\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "frontend:dev": "npm run dev --workspace frontend",
    "backend:dev": "npm run dev --workspace backend",
    "backend:seed": "npm run seed:bootstrap --workspace backend",
    "backend:db:push": "npm run db:push --workspace backend",
    "backend:prisma:generate": "npm run prisma:generate --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
